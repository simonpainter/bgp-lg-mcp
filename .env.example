# BGP Looking Glass MCP Server - Environment Variables
# Copy this file to .env and customize for your deployment

# ============================================================================
# Server Configuration
# ============================================================================

# Transport mode: 'stdio', 'sse', or 'streamable-http' (default)
# - stdio: Standard input/output (for Claude Desktop)
# - streamable-http: HTTP transport with streaming (default, for web clients)
# - sse: Server-Sent Events (alternative HTTP mode)
TRANSPORT_MODE=streamable-http

# Server host for HTTP mode (default: 127.0.0.1)
# Use 0.0.0.0 to listen on all interfaces (Azure deployment)
SERVER_HOST=0.0.0.0

# Server port for HTTP mode (default: 8000)
# Azure App Service typically uses port 8000 or auto-assigned port via PORT env var
SERVER_PORT=8000

# ============================================================================
# Configuration File
# ============================================================================

# Path to config.json file containing route servers configuration
# If not set, uses config.json in the same directory as server.py
# CONFIG_PATH=/path/to/config.json

# ============================================================================
# BGP Connection Settings
# ============================================================================

# Default timeout for BGP server connections (in seconds)
# Applies to all servers unless overridden in config.json
# Useful for slow networks or unreliable connections
# BGP_SERVER_TIMEOUT=15

# ============================================================================
# Logging
# ============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# ============================================================================
# Notes
# ============================================================================
# 
# For Azure App Service deployment:
# - Set SERVER_HOST=0.0.0.0
# - Set TRANSPORT_MODE=streamable-http
# - Azure automatically sets PORT environment variable, which we map to SERVER_PORT
# 
# For local development:
# - Leave defaults (127.0.0.1:8000)
# - Set LOG_LEVEL=DEBUG for verbose output
# 
# To use this file, load it before starting the server:
#   export $(cat .env | xargs)
#   python3 server.py
